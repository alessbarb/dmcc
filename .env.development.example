# Local development template. Copy to .env for local use only.
NODE_ENV=development
DMCC_HOST=127.0.0.1
PORT=
DMCC_PORT=4877
DMCC_PUBLIC_ORIGIN=http://127.0.0.1:4877
PUBLIC_ORIGIN=http://127.0.0.1:4877
DMCC_TRUST_PROXY_HOPS=0
DMCC_STORAGE_MODE=legacy
DATABASE_URL=
DATABASE_POOL_MAX=5
# Required only when DMCC_STORAGE_MODE=postgres. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
DMCC_DATA_DIR=
DMCC_PUBLIC_DIR=
DMCC_PREMADE_DIR=
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
EMAIL_FROM="DM Campaign Companion <dmcampaigncompanion@gmail.com>"
PUBLIC_APP_URL=http://127.0.0.1:4877
# Local development only; never enable outside a private local environment.
DMCC_DEV_PASSWORD_RESET_TOKEN_RESPONSE=false
DMCC_DEV_UI_PORT=5173
