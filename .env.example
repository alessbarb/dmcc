# DM Campaign Companion environment template
# Copy one of these templates before editing:
#   cp .env.development.example .env
#   cp .env.production.example .env
#
# This file documents every supported variable with its intended context.
# Do not put real secrets in committed example files.

# ─────────────────────────────────────────────
# General (development and production)
# ─────────────────────────────────────────────
# Runtime mode. Use "development" locally and "production" for deployed builds.
NODE_ENV=development

# ─────────────────────────────────────────────
# Server / Network (development and production)
# ─────────────────────────────────────────────
# Hostname the server binds to (read via resolveListenHost → DMCC_HOST).
# Development: 127.0.0.1 keeps the app loopback-only; 0.0.0.0 exposes it on LAN.
# Production: do not expose DMCC_HOST=0.0.0.0 directly to the internet unless a
# hardened reverse proxy, TLS, firewall rules, rate limits, and trusted-proxy
# settings are in place.
DMCC_HOST=127.0.0.1

# TCP port. PORT takes precedence (common on PaaS), then DMCC_PORT, then 4877.
# Development: leave PORT blank and use DMCC_PORT. Production: set PORT only if
# your platform injects it; otherwise set DMCC_PORT explicitly.
PORT=
DMCC_PORT=4877

# Public-facing origin (scheme + host + optional port).
# Used for CORS, CSRF validation, and OAuth redirect URIs.
# Development: http://127.0.0.1:4877. Production: your HTTPS origin.
DMCC_PUBLIC_ORIGIN=http://127.0.0.1:4877
PUBLIC_ORIGIN=http://127.0.0.1:4877

# Number of trusted proxy hops for Fastify IP normalization.
# Development/direct traffic: leave blank or set 0.
# Production behind one trusted reverse proxy (for example Render): set 1.
# Do not set this to true, and do not trust arbitrary client-supplied proxy headers.
DMCC_TRUST_PROXY_HOPS=0

# ─────────────────────────────────────────────
# Storage mode (development and production)
# ─────────────────────────────────────────────
# Set to "postgres" to enable the web/app model (PostgreSQL, web accounts,
# campaign memberships, invitations). Default: "legacy" (file-based).
# Development may use either "legacy" or a local Postgres. Production web accounts
# require "postgres" plus a managed database.
DMCC_STORAGE_MODE=legacy

# ─────────────────────────────────────────────
# Database (Postgres / Neon; required when DMCC_STORAGE_MODE=postgres)
# ─────────────────────────────────────────────
# Development example: postgresql://dmcc:dmcc_password@localhost:5432/dmcc
# Production: set this in your secret manager with strong, non-default database
# credentials and sslmode=require when your provider requires TLS.
DATABASE_URL=
DATABASE_POOL_MAX=5

# ─────────────────────────────────────────────
# Session / Auth (required when DMCC_STORAGE_MODE=postgres)
# ─────────────────────────────────────────────
# Generate a unique secret per environment, store it only in your secret manager,
# and never commit or reuse it. Recommended generation command:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─────────────────────────────────────────────
# File paths (optional overrides; development and production)
# ─────────────────────────────────────────────
# Absolute path to the data directory (default: ~/Documents/DMCampaignCompanion).
DMCC_DATA_DIR=

# Absolute path to built frontend assets (default: auto-resolved dist/public).
DMCC_PUBLIC_DIR=

# Absolute path to the premade-campaigns directory (default: public/premades).
DMCC_PREMADE_DIR=

# ─────────────────────────────────────────────
# Email / SMTP (password recovery; production recommended)
# ─────────────────────────────────────────────
# Email provider for password recovery.
# Development: optional if using the development reset-token response below.
# Production: configure a real provider; Render Free blocks SMTP ports, so use an
# HTTP email API such as Brevo instead of raw SMTP.
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
EMAIL_FROM="DM Campaign Companion <dmcampaigncompanion@gmail.com>"
PUBLIC_APP_URL=http://127.0.0.1:4877

# ─────────────────────────────────────────────
# Development-only helpers
# ─────────────────────────────────────────────
# Port of the Vite dev server (used to redirect /join/* in non-SPA mode).
DMCC_DEV_UI_PORT=5173

# Return the raw password-reset token in the forgot-password API response.
# Use only for local development when SMTP is not configured. Never enable in
# production because it exposes account-recovery tokens to API callers.
DMCC_DEV_PASSWORD_RESET_TOKEN_RESPONSE=false

# ─────────────────────────────────────────────
# Production hardening checklist
# ─────────────────────────────────────────────
# - Set NODE_ENV=production.
# - Use HTTPS at DMCC_PUBLIC_ORIGIN/PUBLIC_ORIGIN/PUBLIC_APP_URL.
# - Generate SESSION_SECRET with the command above and store it as a secret.
# - Use DMCC_STORAGE_MODE=postgres with non-default database credentials.
# - Do not reuse docker-compose or local-development credentials in production.
# - Do not run a public deployment with DMCC_HOST=0.0.0.0 unless protected by a
#   hardened reverse proxy, TLS, firewall rules, rate limits, and correct
#   DMCC_TRUST_PROXY_HOPS settings.
# - Keep DMCC_DEV_PASSWORD_RESET_TOKEN_RESPONSE=false.
