# ─────────────────────────────────────────────
# General
# ─────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────
# Server / Network
# ─────────────────────────────────────────────
# Hostname the server binds to (read via resolveListenHost → DMCC_HOST).
# Use 0.0.0.0 to expose on LAN; 127.0.0.1 for loopback-only.
DMCC_HOST=0.0.0.0

# TCP port. PORT takes precedence (common on PaaS), then DMCC_PORT, then 4877.
PORT=
DMCC_PORT=4877

# Public-facing origin (scheme + host + optional port).
# Used for CORS, CSRF validation, and OAuth redirect URIs.
DMCC_PUBLIC_ORIGIN=https://your-app.example.com
PUBLIC_ORIGIN=https://your-app.example.com

# ─────────────────────────────────────────────
# Storage mode
# ─────────────────────────────────────────────
# Set to "postgres" to enable the web/app model (PostgreSQL, web accounts,
# campaign memberships, invitations). Default: "legacy" (file-based).
DMCC_STORAGE_MODE=postgres

# ─────────────────────────────────────────────
# Database (Postgres / Neon)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_POOL_MAX=5

# ─────────────────────────────────────────────
# Session / Auth
# ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# ─────────────────────────────────────────────
# File paths (optional overrides)
# ─────────────────────────────────────────────
# Absolute path to the data directory (default: ~/Documents/DMCampaignCompanion).
DMCC_DATA_DIR=

# Absolute path to built frontend assets (default: auto-resolved dist/public).
DMCC_PUBLIC_DIR=

# Absolute path to the premade-campaigns directory (default: public/premades).
DMCC_PREMADE_DIR=

# ─────────────────────────────────────────────
# Email / SMTP (password recovery)
# ─────────────────────────────────────────────
# Email provider for password recovery.
# Render Free blocks SMTP ports, so production should use an HTTP email API.
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
EMAIL_FROM="DM Campaign Companion <dmcampaigncompanion@gmail.com>"
PUBLIC_APP_URL=http://127.0.0.1:4877

# Development only. Never enable in production.
DMCC_DEV_PASSWORD_RESET_TOKEN_RESPONSE=false

# ─────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────
# Port of the Vite dev server (used to redirect /join/* in non-SPA mode).
DMCC_DEV_UI_PORT=5173
# Set to "true" (only in non-production) to return the raw reset token in the
# forgot-password API response — useful when SMTP is not configured locally.
# NEVER set this in production; in production tokens are never exposed.
DMCC_DEV_PASSWORD_RESET_TOKEN_RESPONSE=false