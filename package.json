{
  "name": "dmcc",
  "version": "0.7.0",
  "author": {
    "name": "Alessandro Barbagallo",
    "email": "alessbarb@gmail.com"
  },
  "private": true,
  "type": "module",
  "description": "Web-first campaign memory and player portal for tabletop RPGs.",
  "scripts": {
    "archive": "node scripts/archive.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:release": "node -e \"require('node:fs').rmSync('release', { recursive: true, force: true })\"",
    "assets:thumbs": "tsx scripts/generate-asset-thumbs.ts",
    "assets:thumbs:dist": "DMCC_ASSETS_ROOT=dist/public/assets tsx scripts/generate-asset-thumbs.ts",
    "build": "npm run clean && vite build && npm run assets:thumbs:dist && tsc -p tsconfig.build.json && node scripts/fix-dist-imports.mjs",
    "start": "node dist/src/backend/entry/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "audit:unused": "knip --no-config-hints",
    "audit:unused:prod": "knip --production --strict --no-config-hints",
    "audit:orphans": "madge --extensions ts,tsx --ts-config tsconfig.node.json --orphans src",
    "audit:cycles": "madge --extensions ts,tsx --ts-config tsconfig.node.json --circular src",
    "audit:duplicates": "jscpd src tests --reporters console --min-lines 20 --min-tokens 100 --ignore \"**/db/migrations/meta/**\"",
    "audit:deps": "dependency-cruiser --config .dependency-cruiser.cjs src --output-type err",
    "audit:cleanup": "node scripts/audit-cleanup.mjs",
    "typecheck": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:app",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "tsx watch --tsconfig tsconfig.node.json src/backend/entry/index.ts",
    "dev:ui": "vite",
    "dev": "tsx watch --tsconfig tsconfig.node.json src/backend/entry/index.ts & vite",
    "test:e2e": "playwright test",
    "quality:typecheck": "npm run typecheck:all",
    "quality:test": "npm test",
    "quality:build": "npm run build",
    "quality": "npm run quality:lint && npm run quality:typecheck && npm run quality:test && npm run quality:build",
    "quality:all": "npm run quality && npm run quality:e2e",
    "quality:e2e": "npm run test:e2e",
    "quality:lint": "npm run lint",
    "premade:build": "node scripts/premades/build.mjs",
    "premade:build:check": "node scripts/premades/build.mjs --check",
    "premade:validate": "node scripts/premades/validate.mjs",
    "dev:db": "docker compose up -d postgres",
    "db:migrate": "dotenv -e .env -- tsx src/backend/db/migrate.ts",
    "db:whoami": "dotenv -e .env -- node -e \"import('pg').then(async ({default: pg}) => { const url = process.env.DATABASE_URL; const parsed = url ? new URL(url) : undefined; const mode = (process.env.DATABASE_SSL_MODE || 'auto').toLowerCase(); const local = parsed && ['localhost','127.0.0.1','::1','[::1]'].includes(parsed.hostname.toLowerCase()); const socket = parsed && (parsed.searchParams.has('host') || parsed.hostname.startsWith('/')); const remote = parsed && !local && !socket; if (!url) throw new Error('DATABASE_URL is required'); if (!['auto','require','disable'].includes(mode)) throw new Error('DATABASE_SSL_MODE must be auto, require, or disable'); if (process.env.NODE_ENV === 'production' && remote && mode === 'disable') throw new Error('DATABASE_SSL_MODE=disable is not allowed for remote production databases'); const pool = new pg.Pool({ connectionString: url, ssl: mode === 'disable' ? undefined : (mode === 'require' || remote ? true : undefined) }); const r = await pool.query('select current_database() db, current_user usr, inet_server_addr() addr, version() version'); console.log(r.rows[0]); await pool.end(); })\"",
    "db:studio": "drizzle-kit studio",
    "db:migrate:prod": "tsx src/backend/db/migrate.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm test && npm run test:integration"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@tanstack/react-router": "^1.170.16",
    "@xyflow/react": "^12.11.2",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.21.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-3d": "^1.29.1",
    "three": "^0.185.0",
    "three-spritetext": "^1.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "dependency-cruiser": "^18.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "jscpd": "^5.0.12",
    "knip": "^6.26.0",
    "madge": "^8.0.0",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.4"
    }
  }
}
