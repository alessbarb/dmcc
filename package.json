{
  "name": "dmcc",
  "version": "0.1.0",
  "author": {
    "name": "Alessandro Barbagallo",
    "email": "alessbarb@gmail.com"
  },
  "private": true,
  "type": "module",
  "description": "Local-first campaign memory and player portal for tabletop RPGs.",
  "main": "desktop/main.mjs",
  "desktopName": "local.dmcc.app.desktop",
  "scripts": {
    "archive": "mkdir -p dist && git ls-files -z --cached --others --exclude-standard | tar --null -czf dist/dmcc.tar.gz --files-from=-",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:release": "node -e \"require('node:fs').rmSync('release', { recursive: true, force: true })\"",
    "clean:desktop": "npm run clean && npm run clean:release",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json && node scripts/fix-dist-imports.mjs",
    "start": "node dist/src/backend/entry/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:app",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "tsx watch src/backend/entry/index.ts",
    "dev:ui": "vite",
    "dev": "tsx watch src/backend/entry/index.ts & vite",
    "test:e2e": "playwright test",
    "quality:typecheck": "npm run typecheck:all",
    "quality:test": "npm test",
    "quality:build": "npm run build",
    "quality": "npm run quality:lint && npm run quality:typecheck && npm run quality:test && npm run quality:build",
    "quality:all": "npm run quality && npm run quality:e2e",
    "quality:e2e": "npm run test:e2e",
    "quality:lint": "npm run lint",
    "seed:oracle": "tsx seeds/campaigns/oracle/seed.ts",
    "seed:oracle:dry": "DMCC_SEED_MODE=dry-run tsx seeds/campaigns/oracle/seed.ts",
    "seed:oracle:replace": "DMCC_SEED_MODE=replace DMCC_SEED_CONFIRM=\"La Sombra del Oráculo\" tsx seeds/campaigns/oracle/seed.ts",
    "seed:phandalin": "tsx seeds/campaigns/phandalin/seed.ts",
    "seed:phandalin:dry": "DMCC_SEED_MODE=dry-run tsx seeds/campaigns/phandalin/seed.ts",
    "seed:phandalin:replace": "DMCC_SEED_MODE=replace DMCC_SEED_CONFIRM=\"Las Sombras sobre Phandalin\" tsx seeds/campaigns/phandalin/seed.ts",
    "gen:icons": "node scripts/generate-icons.mjs",
    "desktop:dev": "npm run build && electron desktop/main.mjs",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:release": "node scripts/desktop-release.mjs",
    "desktop:release:clean": "node scripts/desktop-release.mjs --clean",
    "desktop:build": "npm run desktop:release:clean",
    "desktop:linux": "npm run build && electron-builder --linux AppImage deb",
    "desktop:win": "npm run build && electron-builder --win nsis portable",
    "desktop:win:dir": "npm run build && electron-builder --win --dir",
    "desktop:win:portable": "npm run build && electron-builder --win portable",
    "desktop:win:installer": "npm run build && electron-builder --win nsis",
    "desktop:mac": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@tanstack/react-router": "^1.170.16",
    "fastify": "^5.8.5",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-3d": "^1.29.1",
    "reactflow": "^11.11.4",
    "three": "^0.185.0",
    "three-spritetext": "^1.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.6",
    "eslint": "^10.5.0",
    "sharp": "^0.35.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "local.dmcc.app",
    "productName": "DM Campaign Companion",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "desktop/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.mjs"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "icon": "build/icons",
      "syncDesktopName": true
    },
    "deb": {
      "maintainer": "Alessandro Barbagallo <alessbarb@gmail.com>"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games"
    }
  }
}