{
  "name": "dmcc",
  "version": "0.7.0",
  "author": {
    "name": "Alessandro Barbagallo",
    "email": "alessbarb@gmail.com"
  },
  "private": true,
  "type": "module",
  "description": "Web-first campaign memory and player portal for tabletop RPGs.",
  "scripts": {
    "archive": "node scripts/archive.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:release": "node -e \"require('node:fs').rmSync('release', { recursive: true, force: true })\"",
    "assets:thumbs": "tsx scripts/generate-asset-thumbs.ts",
    "assets:thumbs:dist": "DMCC_ASSETS_ROOT=dist/public/assets tsx scripts/generate-asset-thumbs.ts",
    "build": "npm run clean && vite build && npm run assets:thumbs:dist && tsc -p tsconfig.build.json && node scripts/fix-dist-imports.mjs",
    "start": "node dist/src/backend/entry/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:report": "eslint . --format json --output-file .artifacts/eslint-report.json",
    "audit:unused": "knip --no-config-hints",
    "audit:unused:prod": "knip --production --strict --no-config-hints",
    "audit:orphans": "knip --files --no-config-hints",
    "audit:cycles": "knip --cycles --reporter cycles --no-config-hints",
    "audit:duplicates": "jscpd src tests --reporters console --min-lines 20 --min-tokens 100 --ignore \"**/db/migrations/meta/**\"",
    "audit:deps": "dependency-cruiser --config .dependency-cruiser.cjs src --output-type err",
    "audit:cleanup": "node scripts/audit-cleanup.mjs",
    "typecheck": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:app",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "dotenv -e .env.test -v NODE_ENV=test -- vitest run --config vitest.integration.config.ts",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:all": "npm test && npm run test:integration",
    "test:db:prepare": "npm run dev:db && dotenv -e .env.test -v NODE_ENV=test -- tsx scripts/test/prepareDatabase.ts && npm run db:migrate:test",
    "dev:server:raw": "tsx watch --tsconfig tsconfig.node.json src/backend/entry/index.ts",
    "dev:ui:raw": "vite --mode development",
    "dev:server": "dotenv -e .env.development -v NODE_ENV=development -- npm run dev:server:raw",
    "dev:ui": "dotenv -e .env.development -v NODE_ENV=development -- npm run dev:ui:raw",
    "dev:db": "docker compose up -d postgres",
    "dev": "dotenv -e .env.development -v NODE_ENV=development -- concurrently --kill-others-on-fail --names backend,ui \"npm:dev:server:raw\" \"npm:dev:ui:raw\"",
    "quality:typecheck": "npm run typecheck:all",
    "quality:test": "npm run test:all",
    "quality:build": "npm run build",
    "quality": "npm run quality:lint && npm run quality:typecheck && npm run quality:test && npm run quality:build",
    "quality:all": "npm run quality && npm run quality:e2e",
    "quality:e2e": "npm run test:e2e",
    "quality:lint": "npm run lint",
    "templates:build": "tsx --tsconfig tsconfig.node.json scripts/campaign-templates/build.ts",
    "templates:build:check": "tsx --tsconfig tsconfig.node.json scripts/campaign-templates/build.ts --check",
    "templates:validate": "tsx --tsconfig tsconfig.node.json scripts/campaign-templates/validate.ts",
    "templates:schema:check": "tsx --tsconfig tsconfig.node.json scripts/campaign-templates/generateSchemas.ts --check",
    "templates:schema:generate": "tsx --tsconfig tsconfig.node.json scripts/campaign-templates/generateSchemas.ts",
    "admin:reset-campaign-domain": "tsx scripts/admin/resetCampaignDomain.ts",
    "admin:reset-campaign-domain:development": "dotenv -e .env.development -v NODE_ENV=development -- npm run admin:reset-campaign-domain",
    "db:whoami": "tsx scripts/db/whoami.ts",
    "db:whoami:development": "dotenv -e .env.development -v NODE_ENV=development -- npm run db:whoami",
    "db:whoami:test": "dotenv -e .env.test -v NODE_ENV=test -- npm run db:whoami",
    "db:studio": "dotenv -e .env.development -v NODE_ENV=development -- drizzle-kit studio",
    "db:migrate": "tsx src/backend/db/migrate.ts",
    "db:migrate:development": "dotenv -e .env.development -v NODE_ENV=development -- npm run db:migrate",
    "db:migrate:test": "dotenv -e .env.test -v NODE_ENV=test -- npm run db:migrate"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@tanstack/react-router": "^1.170.17",
    "@xyflow/react": "^12.11.2",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "elkjs": "^0.11.1",
    "fastify": "^5.10.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.24.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-3d": "^1.29.1",
    "three": "^0.185.1",
    "three-spritetext": "^1.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "dependency-cruiser": "^18.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "jscpd": "^5.0.12",
    "knip": "^6.26.0",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.4"
    }
  }
}