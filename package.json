{
  "name": "dmcc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "archive": "mkdir -p dist && git ls-files -z --cached --others --exclude-standard | tar --null -czf dist/dmcc.tar.gz --files-from=-",
    "build": "vite build && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:app": "tsc -p tsconfig.app.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:app",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "tsx watch src/main/index.ts",
    "dev:ui": "vite",
    "dev": "tsx watch src/main/index.ts & vite",
    "start": "node dist/main/index.js",
    "test:e2e": "playwright test",
    "quality:typecheck": "npm run typecheck:all",
    "quality:test": "npm test",
    "quality:build": "npm run build",
    "quality": "npm run quality:lint && npm run quality:typecheck && npm run quality:test && npm run quality:build",
    "quality:all": "npm run quality && npm run quality:e2e",
    "quality:e2e": "npm run test:e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "quality:lint": "npm run lint"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@tanstack/react-router": "^1.170.16",
    "fastify": "^5.8.5",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-force-graph-3d": "^1.29.1",
    "reactflow": "^11.11.4",
    "three": "^0.185.0",
    "three-spritetext": "^1.10.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
