# Production template. Copy values into your deployment secret manager; do not
# commit filled-in production secrets.
NODE_ENV=production
# Prefer binding to a private interface behind a reverse proxy when possible.
# If your platform requires 0.0.0.0, add TLS, firewall/routing controls, rate
# limits, and correct trusted-proxy configuration before exposing the service.
DMCC_HOST=127.0.0.1
PORT=
DMCC_PORT=4877
DMCC_PUBLIC_ORIGIN=https://your-app.example.com
PUBLIC_ORIGIN=https://your-app.example.com
# Set to the exact number of trusted reverse proxies in front of the app.
DMCC_TRUST_PROXY_HOPS=1
DMCC_STORAGE_MODE=postgres
# Set in secret manager with strong, non-default database credentials.
DATABASE_URL=
DATABASE_POOL_MAX=5
# Generate per environment with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
DMCC_DATA_DIR=
DMCC_PUBLIC_DIR=
DMCC_PREMADE_DIR=
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
EMAIL_FROM="DM Campaign Companion <dmcampaigncompanion@gmail.com>"
PUBLIC_APP_URL=https://your-app.example.com
# Must remain false in production.
DMCC_DEV_PASSWORD_RESET_TOKEN_RESPONSE=false
