{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "number"
    },
    "templateId": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "system": {
      "type": "string",
      "enum": [
        "dnd_5e",
        "pathfinder_2e",
        "shadowdark",
        "custom"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "starter",
        "medium",
        "advanced"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "number"
        },
        "relations": {
          "type": "number"
        },
        "facts": {
          "type": "number"
        },
        "preparedSessions": {
          "type": "number"
        }
      },
      "required": [
        "entities",
        "relations",
        "facts",
        "preparedSessions"
      ],
      "additionalProperties": false
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entityId": {
            "type": "string"
          },
          "entityType": {
            "type": "string"
          },
          "importance": {
            "type": "string",
            "enum": [
              "low",
              "normal",
              "high",
              "critical"
            ]
          },
          "visibility": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": {}
          },
          "metadata": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          }
        },
        "required": [
          "entityId",
          "entityType"
        ],
        "additionalProperties": false
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "relationId": {
            "type": "string"
          },
          "sourceEntityId": {
            "type": "string"
          },
          "targetEntityId": {
            "type": "string"
          },
          "relationType": {
            "type": "string"
          },
          "visibility": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": {}
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "relationId",
          "sourceEntityId",
          "targetEntityId",
          "relationType"
        ],
        "additionalProperties": false
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "factId": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "canon",
              "dm_secret",
              "rumor",
              "lie",
              "player_theory",
              "mistake",
              "retcon",
              "unknown"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "unconfirmed",
              "suspected",
              "likely",
              "confirmed",
              "false"
            ]
          },
          "visibility": {
            "type": "object",
            "properties": {
              "kind": {
                "type": "string"
              }
            },
            "required": [
              "kind"
            ],
            "additionalProperties": {}
          },
          "relatedEntityIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relatedRelationIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "statement": {
            "type": "string"
          }
        },
        "required": [
          "factId",
          "kind",
          "confidence"
        ],
        "additionalProperties": false
      }
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "scheduledAt": {
            "type": "string"
          },
          "prep": {
            "type": "object",
            "properties": {
              "state": {
                "type": "string",
                "enum": [
                  "draft",
                  "ready"
                ]
              },
              "summary": {
                "type": "string"
              },
              "openingPrompt": {
                "type": "string"
              },
              "goals": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "sceneIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "involvedEntityIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "availableClueIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "secretsAtRiskIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "expectedConsequenceIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "checklist": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "priority": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    },
                    "label": {
                      "type": "string"
                    },
                    "done": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "id"
                  ],
                  "additionalProperties": false
                }
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "sessionId"
        ],
        "additionalProperties": false
      }
    },
    "canvases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "canvasId": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "world",
              "session",
              "mystery",
              "location",
              "characters",
              "custom"
            ]
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "kind": {
                  "type": "string",
                  "enum": [
                    "entity",
                    "note",
                    "group",
                    "image",
                    "fact"
                  ]
                },
                "entityId": {
                  "type": "string"
                },
                "factId": {
                  "type": "string"
                },
                "groupId": {
                  "type": "string"
                },
                "metadata": {
                  "type": "object",
                  "propertyNames": {
                    "type": "string"
                  },
                  "additionalProperties": {}
                },
                "title": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "color": {
                  "type": "string",
                  "enum": [
                    "yellow",
                    "blue",
                    "green",
                    "pink",
                    "purple"
                  ]
                },
                "x": {
                  "type": "number"
                },
                "y": {
                  "type": "number"
                },
                "width": {
                  "type": "number"
                },
                "height": {
                  "type": "number"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "draft",
                    "ready",
                    "revealed",
                    "resolved"
                  ]
                },
                "visibility": {
                  "type": "string",
                  "enum": [
                    "dm",
                    "public"
                  ]
                }
              },
              "required": [
                "id",
                "kind",
                "x",
                "y"
              ],
              "additionalProperties": false
            }
          },
          "edges": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "sourceNodeId": {
                  "type": "string"
                },
                "targetNodeId": {
                  "type": "string"
                },
                "relationshipId": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "visibility": {
                  "type": "string",
                  "enum": [
                    "dm",
                    "public"
                  ]
                },
                "style": {
                  "type": "string",
                  "enum": [
                    "solid",
                    "dashed",
                    "secret",
                    "weak",
                    "strong"
                  ]
                }
              },
              "required": [
                "id",
                "sourceNodeId",
                "targetNodeId"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "canvasId",
          "kind"
        ],
        "additionalProperties": false
      }
    },
    "highlightEntityIds": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featuredFactIds": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featuredRelationIds": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaultLocale": {
      "type": "string",
      "enum": [
        "en",
        "es",
        "fr",
        "de",
        "it",
        "pt"
      ]
    }
  },
  "required": [
    "templateId",
    "version",
    "system",
    "difficulty",
    "tags",
    "stats",
    "entities",
    "relations",
    "facts",
    "sessions",
    "canvases",
    "highlightEntityIds",
    "featuredFactIds",
    "featuredRelationIds"
  ],
  "additionalProperties": false,
  "$id": "https://dmcc.local/schemas/campaign-template/template/v1.json"
}
