{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dmcc.local/schemas/premade-manifest.schema.json",
  "title": "DMCC Premade Campaign Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "defaultLocale",
    "templates"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "defaultLocale": {
      "$ref": "#/$defs/locale"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/templateEntry"
      }
    }
  },
  "$defs": {
    "locale": {
      "type": "string",
      "enum": [
        "en",
        "es",
        "fr",
        "de",
        "it",
        "pt"
      ]
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entities",
        "relations",
        "facts",
        "preparedSessions"
      ],
      "properties": {
        "entities": {
          "type": "integer",
          "minimum": 0
        },
        "relations": {
          "type": "integer",
          "minimum": 0
        },
        "facts": {
          "type": "integer",
          "minimum": 0
        },
        "preparedSessions": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "templateEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "templateId",
        "version",
        "defaultLocale",
        "availableLocales",
        "templateFile",
        "locales",
        "stats"
      ],
      "properties": {
        "templateId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "defaultLocale": {
          "$ref": "#/$defs/locale"
        },
        "availableLocales": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/locale"
          },
          "uniqueItems": true
        },
        "templateFile": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/template\\.json$"
        },
        "locales": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*/locales/[a-z]{2}\\.json$"
          }
        },
        "stats": {
          "$ref": "#/$defs/stats"
        }
      }
    }
  }
}